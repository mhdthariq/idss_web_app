# ── Vercel ignore ────────────────────────────────────────────
# Force Vercel to use requirements.txt instead of uv.lock
# (uv.lock includes torch ~2GB which exceeds Lambda limits)
uv.lock
pyproject.toml

# Python virtual environment
.venv/
__pycache__/

# Frontend (deployed separately)
frontend/

# Git
.git/

# Large data files not needed by API at runtime
data/raw/
data/processed/train.csv
data/processed/train_augmented.csv
data/processed/train_augmented_full.csv
data/processed/train_original.csv
data/processed/val.csv
data/processed/*.pkl

# Thesis docs
docs/latex/
docs/*.md

# PyTorch model (replaced by ONNX)
models/mlp_v4.pt
models/mlp_shap_values_v4.pkl
models/dl_metrics_v3.json
models/ml_dl_comparison_v3.csv
models/shap_comparison_v4.json
models/computational_cost_v4.json
